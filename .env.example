# Copie este arquivo para .env e preencha os valores reais
# Execute: cp .env.example .env

# OBRIGATÓRIO: Chave secreta para sessões Flask
# Gere uma nova com: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=sua-chave-secreta-aqui

REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://clinica_user:password@postgres:5432/clinica
POSTGRES_PASSWORD=senha_segura_aqui

# Usado apenas por create_admin.py
ADMIN_USERNAME=admin
ADMIN_PASSWORD=troque-esta-senha
